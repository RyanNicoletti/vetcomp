{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "start:prod": "node dist/backend/src/server.js",
    "copy-assets": "mkdir -p dist/backend/assets && cp -R assets/* dist/backend/assets/",
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run copy-assets",
    "migrate:prod": "cd dist/backend/config && npx knex migrate:latest",
    "test": "echo \"Error: no test specified\" && exit 1",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org veterinarycompcom --project node-express ./dist && sentry-cli sourcemaps upload --org veterinarycompcom --project node-express ./dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "@sentry/cli": "^2.36.4",
    "@sentry/node": "^8.32.0",
    "@sentry/profiling-node": "^8.32.0",
    "@types/multer": "^1.4.12",
    "argon2": "^0.41.1",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.11.5",
    "redis": "^4.7.0",
    "typescript": "^5.4.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1"
  }
}