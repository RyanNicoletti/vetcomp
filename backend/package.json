{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "start:prod": "node dist/backend/src/server.js",
    "copy-assets": "mkdir -p dist/backend/assets && cp -R assets/* dist/backend/assets/",
    "dev": "nodemon",
    "build": "tsc && npm run copy-assets",
    "seed": "node --env-file=.env --import=tsx ./node_modules/.bin/knex --knexfile ./config/knexfile.ts seed:run",
    "migrate": "node --env-file=.env --import=tsx ./node_modules/.bin/knex --knexfile ./config/knexfile.ts migrate:latest",
    "migrate:up": "node --env-file=.env --import=tsx ./node_modules/.bin/knex --knexfile ./config/knexfile.ts migrate:up",
    "migrate:down": "node --env-file=.env --import=tsx ./node_modules/.bin/knex --knexfile ./config/knexfile.ts migrate:down",
    "migrate:prod": "cd dist/backend/config && npx knex migrate:latest",
    "test": "vitest run",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org veterinarycompcom --project node-express ./dist && sentry-cli sourcemaps upload --org veterinarycompcom --project node-express ./dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@sentry/cli": "^3.4.3",
    "@sentry/node": "^10.55.0",
    "@sentry/profiling-node": "^10.55.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "argon2": "^0.44.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "openai": "^6.39.1",
    "pg": "^8.11.5",
    "redis": "^6.0.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.8"
  }
}
